      el4.setAttribute('aria-label', I18N[key4][lang]);
    }
  }
  
  // data-caption translation (keep data-i18n-caption attribute on gallery items)
  var caps = document.querySelectorAll('[data-i18n-caption]');
  for (var c = 0; c < caps.length; c++) {
    var el5 = caps[c];
    var key5 = el5.getAttribute('data-i18n-caption');
    if (I18N[key5] && I18N[key5][lang]) {
      el5.setAttribute('data-caption', I18N[key5][lang]);
    }
  }
  
  // Update language button text
  var btnText = document.getElementById('langBtnText');
  if (btnText) btnText.textContent = LANG_NAMES[lang];
  
  // Highlight active language in dropdown
  var dropdownItems = document.querySelectorAll('#langDropdown a');
  for (var d = 0; d < dropdownItems.length; d++) {
    dropdownItems[d].classList.remove('active');
    if (dropdownItems[d].getAttribute('data-lang') === lang) {
      dropdownItems[d].classList.add('active');
    }
  }
  
  // Update page title
  if (I18N['page_title'] && I18N['page_title'][lang]) {
    document.title = I18N['page_title'][lang];
  }
  
  localStorage.setItem('zizai_lang', lang);
}
window.applyLanguage = applyLanguage;


function initI18N() {
  var savedLang = localStorage.getItem('zizai_lang');
  var browserLang = (navigator.language || navigator.userLanguage || '').split('-')[0];
  var supportedLangs = ['zh','en','ja','fr','ru','he','ar','es','de','ko','pt','bo','ug'];
  var lang = 'zh';
  if (savedLang && supportedLangs.indexOf(savedLang) !== -1) {
    lang = savedLang;
  } else if (supportedLangs.indexOf(browserLang) !== -1) {
    lang = browserLang;
  }
  
  // Build dropdown — use existing <a> tags from HTML, or create if absent
  var dropdown = document.getElementById('langDropdown');
  if (dropdown) {
    var existingItems = dropdown.querySelectorAll('a');
    // If dropdown already has static <a> tags, wire them up instead of recreating
    if (existingItems.length > 0) {
      for (var i = 0; i < existingItems.length; i++) {
        var a = existingItems[i];
        a.onclick = function(e) {
          var l = this.getAttribute('data-lang');
          applyLanguage(l);
          document.getElementById('langDropdown').classList.remove('show');
        };
      }
    } else {
      // Fallback: create <a> tags dynamically if dropdown is empty
      dropdown.innerHTML = '';
      for (var i = 0; i < supportedLangs.length; i++) {
        var code = supportedLangs[i];
        var a = document.createElement('a');
        a.setAttribute('data-lang', code);
        a.href = 'javascript:void(0)';
        a.onclick = function(e) {
          var l = this.getAttribute('data-lang');
          applyLanguage(l);
          document.getElementById('langDropdown').classList.remove('show');
        };
        var flag = LANG_FLAGS[code] || '';
        a.textContent = flag + ' ' + LANG_NAMES[code];
        if (code === lang) a.classList.add('active');
        dropdown.appendChild(a);
      }
    }
  }
  
  // Close dropdown on outside click
  document.addEventListener('click', function(e) {
    var dd = document.getElementById('langDropdown');
    var btn = document.getElementById('langBtn');
    if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target)) {
      dd.classList.remove('show');
    }
  });

  // Close dropdown on scroll (wheel / touch)
  document.addEventListener('wheel', function(e) {
    var dd = document.getElementById('langDropdown');
    if (dd && dd.classList.contains('show')) {
      dd.classList.remove('show');
    }
  }, { passive: true });
  
  applyLanguage(lang);
}
window.initI18N = initI18N;

// Init on DOM ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initI18N);
} else {
  initI18N();
}

